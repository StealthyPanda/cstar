
@@grammar::Onions
@@parseinfo :: True


# The Entry Point
start = { sea | @+:island }* ;

# The "Sea" (Junk to ignore)
# It uses a negative lookahead to ensure we don't consume an actual island
sea = !island /./ ;

# The "Island" (The stuff you actually want)
island = external_header ;


external_header =
    '#include' '<' name:identifier '.h>'
    ;


identifier =
    /[a-zA-Z_][a-zA-Z0-9_]*/
    ;

